      "bookcase",
      "bookshelf",
      "armchair",
      "side_table",
      "floor_lamp"
    ]
  },
  "license_policy": {
    "allow": [
      "CC0",
      "CC-BY 4.0"
    ],
    "manual_review": [
      "CC-BY-SA",
      "CC-BY 3.0",
      "CC-BY 2.x"
    ],
    "reject": [
      "CC-BY-NC",
      "CC-BY-NC-SA",
      "unknown"
    ]
  },
  "metadata_filters": {
