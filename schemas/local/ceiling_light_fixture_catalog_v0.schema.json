{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vgm-assets.local/schemas/local/ceiling_light_fixture_catalog_v0.schema.json",
  "title": "Ceiling Light Fixture Catalog v0",
  "description": "Local vgm-assets schema for ceiling-mounted fixture catalogs exported to downstream consumers.",
  "type": "array",
  "items": {
    "$ref": "#/$defs/fixtureRecord"
  },
  "$defs": {
    "fileRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "format"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/).+"
        },
        "format": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo",
        "version",
        "commit"
      ],
      "properties": {
        "repo": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "commit": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "dimensions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "width",
        "depth",
        "height"
      ],
      "properties": {
        "width": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "depth": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "height": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "footprint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "shape",
        "width",
        "depth"
      ],
      "properties": {
        "shape": {
          "type": "string",
          "enum": [
            "rectangle",
            "circle"
          ]
        },
        "width": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "depth": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "producer",
        "config_id",
        "upstream_ids"
      ],
      "properties": {
        "producer": {
          "$ref": "#/$defs/producer"
        },
        "config_id": {
          "type": "string",
          "minLength": 1
        },
        "upstream_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "upstream_bundle_relpath": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/).+"
        }
      }
    },
    "files": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mesh",
        "preview_image"
      ],
      "properties": {
        "mesh": {
          "$ref": "#/$defs/fileRef"
        },
        "preview_image": {
          "$ref": "#/$defs/fileRef"
        },
        "collision_mesh": {
          "$ref": "#/$defs/fileRef"
        }
      }
    },
    "fixtureRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fixture_id",
        "mount_type",
        "sample_weight",
        "dimensions",
        "footprint",
        "files",
        "provenance"
      ],
      "properties": {
        "fixture_id": {
          "type": "string",
          "minLength": 1
        },
        "mount_type": {
          "type": "string",
          "enum": [
            "ceiling"
          ]
        },
        "sample_weight": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "dimensions": {
          "$ref": "#/$defs/dimensions"
        },
        "footprint": {
          "$ref": "#/$defs/footprint"
        },
        "files": {
          "$ref": "#/$defs/files"
        },
        "provenance": {
          "$ref": "#/$defs/provenance"
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "style_tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "nominal_drop_height_m": {
          "type": "number",
          "minimum": 0
        },
        "emission_hints": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "default_intensity_lm": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "default_color_temperature_k": {
              "type": "number",
              "exclusiveMinimum": 0
            }
          }
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "selection_id": {
          "type": "string",
          "minLength": 1
        },
        "source_url": {
          "type": "string",
          "format": "uri"
        },
        "license": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
