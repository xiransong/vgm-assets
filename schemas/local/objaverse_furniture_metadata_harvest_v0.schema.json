{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vgm-assets.local/schemas/local/objaverse_furniture_metadata_harvest_v0.schema.json",
  "title": "Objaverse Furniture Metadata Harvest v0",
  "description": "Local vgm-assets schema for the first Objaverse furniture metadata-harvest artifact.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "harvest_id",
    "source_id",
    "created_at",
    "record_count",
    "records"
  ],
  "properties": {
    "harvest_id": {
      "type": "string",
      "minLength": 1
    },
    "source_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "record_count": {
      "type": "integer",
      "minimum": 0
    },
    "notes": {
      "type": "string"
    },
    "records": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/record"
      }
    }
  },
  "$defs": {
    "bounds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "width",
        "depth",
        "height"
      ],
      "properties": {
        "width": {
          "type": "number",
          "minimum": 0
        },
        "depth": {
          "type": "number",
          "minimum": 0
        },
        "height": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "object_uid",
        "source_url",
        "title",
        "license"
      ],
      "properties": {
        "object_uid": {
          "type": "string",
          "minLength": 1
        },
        "source_url": {
          "type": "string",
          "format": "uri"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "license": {
          "type": "string",
          "minLength": 1
        },
        "source_tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "source_categories": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "description": {
          "type": "string"
        },
        "available_formats": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "thumbnail_url": {
          "type": "string",
          "format": "uri"
        },
        "metadata_path": {
          "type": "string",
          "minLength": 1
        },
        "payload_ref": {
          "type": "string",
          "minLength": 1
        },
        "triangle_count": {
          "type": "integer",
          "minimum": 0
        },
        "vertex_count": {
          "type": "integer",
          "minimum": 0
        },
        "bounds": {
          "$ref": "#/$defs/bounds"
        }
      }
    }
  }
}
