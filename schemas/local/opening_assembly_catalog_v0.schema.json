{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vgm-assets.local/schemas/local/opening_assembly_catalog_v0.schema.json",
  "title": "Opening Assembly Catalog v0",
  "description": "Local vgm-assets schema for opening-bound architectural assemblies exported to downstream consumers.",
  "type": "array",
  "items": {
    "$ref": "#/$defs/openingAssemblyRecord"
  },
  "$defs": {
    "fileRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "format"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/).+"
        },
        "format": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo",
        "version",
        "commit"
      ],
      "properties": {
        "repo": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "commit": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "producer",
        "config_id",
        "upstream_ids"
      ],
      "properties": {
        "producer": {
          "$ref": "#/$defs/producer"
        },
        "config_id": {
          "type": "string",
          "minLength": 1
        },
        "upstream_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "upstream_bundle_relpath": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/).+"
        }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "nominal_width_m",
        "nominal_height_m",
        "max_width_delta_m",
        "max_height_delta_m"
      ],
      "properties": {
        "nominal_width_m": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "nominal_height_m": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "max_width_delta_m": {
          "type": "number",
          "minimum": 0
        },
        "max_height_delta_m": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "files": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mesh",
        "preview_image"
      ],
      "properties": {
        "mesh": {
          "$ref": "#/$defs/fileRef"
        },
        "preview_image": {
          "$ref": "#/$defs/fileRef"
        },
        "collision_mesh": {
          "$ref": "#/$defs/fileRef"
        }
      }
    },
    "openingAssemblyRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assembly_id",
        "opening_type",
        "sample_weight",
        "compatibility",
        "files",
        "provenance"
      ],
      "properties": {
        "assembly_id": {
          "type": "string",
          "minLength": 1
        },
        "opening_type": {
          "type": "string",
          "enum": [
            "door",
            "window"
          ]
        },
        "sample_weight": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "compatibility": {
          "$ref": "#/$defs/compatibility"
        },
        "files": {
          "$ref": "#/$defs/files"
        },
        "provenance": {
          "$ref": "#/$defs/provenance"
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "style_tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "frame_depth_m": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "door_swing": {
          "type": "string",
          "enum": [
            "left_in",
            "right_in",
            "left_out",
            "right_out",
            "sliding",
            "fixed"
          ]
        },
        "glazing": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "is_glazed": {
              "type": "boolean"
            },
            "transparency": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "selection_id": {
          "type": "string",
          "minLength": 1
        },
        "source_url": {
          "type": "string",
          "format": "uri"
        },
        "license": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
