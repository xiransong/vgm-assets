{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vgm-assets.local/schemas/local/wall_fixture_catalog_v0.schema.json",
  "title": "Wall Fixture Catalog v0",
  "description": "Local vgm-assets schema for wall-mounted decorative fixture catalogs exported to downstream consumers.",
  "type": "array",
  "items": {
    "$ref": "#/$defs/wallFixtureRecord"
  },
  "$defs": {
    "fileRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "format"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/).+"
        },
        "format": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repo",
        "version",
        "commit"
      ],
      "properties": {
        "repo": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "commit": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "producer",
        "config_id",
        "upstream_ids"
      ],
      "properties": {
        "producer": {
          "$ref": "#/$defs/producer"
        },
        "config_id": {
          "type": "string",
          "minLength": 1
        },
        "upstream_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "upstream_bundle_relpath": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/).+"
        }
      }
    },
    "dimensions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "width_m",
        "height_m",
        "depth_m"
      ],
      "properties": {
        "width_m": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "height_m": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "depth_m": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "mount": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mount_type",
        "mount_plane",
        "usable_margin_m"
      ],
      "properties": {
        "mount_type": {
          "type": "string",
          "enum": [
            "wall_mounted"
          ]
        },
        "mount_plane": {
          "type": "string",
          "enum": [
            "vertical_wall"
          ]
        },
        "usable_margin_m": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "heightBand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "min_center_height_m",
        "max_center_height_m"
      ],
      "properties": {
        "min_center_height_m": {
          "type": "number",
          "minimum": 0
        },
        "max_center_height_m": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "files": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mesh",
        "preview_image"
      ],
      "properties": {
        "mesh": {
          "$ref": "#/$defs/fileRef"
        },
        "preview_image": {
          "$ref": "#/$defs/fileRef"
        },
        "collision_mesh": {
          "$ref": "#/$defs/fileRef"
        }
      }
    },
    "wallFixtureRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fixture_id",
        "category",
        "sample_weight",
        "dimensions",
        "mount",
        "files",
        "provenance"
      ],
      "properties": {
        "fixture_id": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "enum": [
            "painting",
            "clock"
          ]
        },
        "sample_weight": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "dimensions": {
          "$ref": "#/$defs/dimensions"
        },
        "mount": {
          "$ref": "#/$defs/mount"
        },
        "files": {
          "$ref": "#/$defs/files"
        },
        "provenance": {
          "$ref": "#/$defs/provenance"
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "style_tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "preferred_height_band_m": {
          "$ref": "#/$defs/heightBand"
        },
        "preferred_room_types": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "review_status": {
          "type": "string",
          "enum": [
            "draft",
            "reviewed",
            "approved"
          ]
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "selection_id": {
          "type": "string",
          "minLength": 1
        },
        "source_url": {
          "type": "string",
          "format": "uri"
        },
        "license": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
